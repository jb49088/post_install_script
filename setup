#!/usr/bin/env bash

# ================================================================================
# =                                    SETUP                                     =
# ================================================================================

set -euo pipefail

MACHINE=""

select_machine() {
    while true; do
        read -r -p "Select machine [wsl/pi/kali]: " MACHINE
        case "$MACHINE" in
            wsl | pi | kali) return ;;
            *) echo "Invalid option" >&2 ;;
        esac
    done
}

setup_locale() {
    # Enable en_US.UTF-8 UTF-8
    sudo sed --in-place 's/# en_US.UTF-8 UTF-8/en_US.UTF-8 UTF-8/' /etc/locale.gen

    # Compile en_US.UTF-8 UTF-8
    sudo locale-gen

    # Set en_US.UTF-8 UTF-8 as default locale
    echo "LANG=en_US.UTF-8" | sudo tee /etc/locale.conf
}

hush_login() {
    touch "$HOME/.hushlogin"
}

update_system() {
    case "$MACHINE" in
        wsl) sudo pacman -Syu --noconfirm ;;
        pi) sudo apt update && sudo apt upgrade --yes ;;
        kali) sudo apt update && sudo apt upgrade --yes ;;
    esac
}

bootstrap_yay() {
    sudo pacman -S --noconfirm git base-devel
    git clone https://aur.archlinux.org/yay.git "$HOME/yay"
    (cd "$HOME/yay" && makepkg --syncdeps --install --noconfirm) # Build arch package from source
    rm --recursive --force "$HOME/yay"
}

install_packages() {
    case "$MACHINE" in
        # Get list of packages and pass it into corresponding package manager with xargs
        wsl) curl --location --fail --retry 3 --retry-delay 2 --retry-all-errors \
            https://raw.githubusercontent.com/jb49088/setup_script/master/packages/wsl/yay.txt \
            | xargs --no-run-if-empty yay -S --noconfirm ;;

        pi) curl --location --fail --retry 3 --retry-delay 2 --retry-all-errors \
            https://raw.githubusercontent.com/jb49088/setup_script/master/packages/pi/apt.txt \
            | xargs --no-run-if-empty sudo apt install --yes ;;

        kali) curl --location --fail --retry 3 --retry-delay 2 --retry-all-errors \
            https://raw.githubusercontent.com/jb49088/setup_script/master/packages/kali/apt.txt \
            | xargs --no-run-if-empty sudo apt install --yes ;;
    esac
}

install_neovim() {
    case "$MACHINE" in
        pi)
            # Get latest neovim release, decompress, and extract
            curl --location --fail --retry 3 --retry-delay 2 --retry-all-errors \
                https://github.com/neovim/neovim/releases/latest/download/nvim-linux-arm64.tar.gz \
                | gzip --decompress --stdout \
                | sudo tar --extract --file=- --directory=/opt

            # Link binary to /usr/local/bin/nvim for PATH access
            sudo ln --symbolic "/opt/nvim-linux-arm64/bin/nvim" "/usr/local/bin/nvim"
            ;;

        kali)
            curl --location --fail --retry 3 --retry-delay 2 --retry-all-errors \
                https://github.com/neovim/neovim/releases/latest/download/nvim-linux-x86_64.tar.gz \
                | gzip --decompress --stdout \
                | sudo tar --extract --file=- --directory=/opt

            sudo ln --symbolic "/opt/nvim-linux-x86_64/bin/nvim" "/usr/local/bin/nvim"
            ;;
    esac
}

install_yazi() {
    case "$MACHINE" in
        pi)
            curl --location --fail --remote-name --retry 3 --retry-delay 2 --retry-all-errors \
                https://github.com/sxyazi/yazi/releases/latest/download/yazi-aarch64-unknown-linux-gnu.deb

            sudo apt install --yes yazi-aarch64-unknown-linux-gnu.deb

            rm yazi-aarch64-unknown-linux-gnu.deb
            ;;
        kali)
            curl --location --fail --remote-name --retry 3 --retry-delay 2 --retry-all-errors \
                https://github.com/sxyazi/yazi/releases/latest/download/yazi-x86_64-unknown-linux-gnu.deb

            sudo apt install --yes yazi-x86_64-unknown-linux-gnu.deb

            rm yazi-x86_64-unknown-linux-gnu.deb
            ;;
    esac
}

install_deskflow() {
    local version
    version=$(curl --location --fail --remote-name --retry 3 --retry-delay 2 --retry-all-errors \
        https://api.github.com/repos/deskflow/deskflow/releases/latest \
        | grep '"tag_name"' | cut -d'"' -f4 | tr -d 'v') # Extract version from json

    curl --location --fail --remote-name --retry 3 --retry-delay 2 --retry-all-errors \
        "https://github.com/deskflow/deskflow/releases/latest/download/deskflow-${version}-debian-trixie-x86_64.deb"

    sudo apt install --yes "deskflow-${version}-debian-trixie-x86_64.deb"

    rm "deskflow-${version}-debian-trixie-x86_64.deb"
}

install_optional_software() {
    case "$MACHINE" in
        pi)
            install_neovim
            install_yazi
            ;;
        kali)
            install_neovim
            install_yazi
            install_deskflow
            ;;
    esac
}

prompt_for_secrets() {
    export RESTIC_REPOSITORY RESTIC_PASSWORD B2_ACCOUNT_ID B2_ACCOUNT_KEY

    while true; do
        read -r -p "Enter Restic repository: " RESTIC_REPOSITORY
        read -r -s -p "Enter Restic password: " RESTIC_PASSWORD && echo
        read -r -p "Enter B2 account ID: " B2_ACCOUNT_ID
        read -r -s -p "Enter B2 account key: " B2_ACCOUNT_KEY && echo

        # Exit loop on valid credentials
        restic snapshots &>/dev/null && return

        echo "Invalid credentials" >&2
    done
}

restore_from_restic() {
    local tags=(
        "ssh" "wsl" "nftables" "services" "bash" "databases" "direnv" "dotfiles"
        "helix" "history" "kakoune" "nvim" "powershell" "python" "sql"
        "sqliterc" "vault" "yazi" "wt" "zellij" "zsh" "lightdm" "autostart"
        "redshift"
    )

    local sudo_tags=("wsl" "nftables" "services" "lightdm")

    # Loop over tags array and restore corresponding restic snapshots using sudo when necesary
    for tag in "${tags[@]}"; do
        local cmd="restic"
        [[ " ${sudo_tags[*]} " == *" $tag "* ]] && cmd="sudo --preserve-env restic"
        $cmd restore latest --tag "$tag" --host "$MACHINE" --target / 2>/dev/null || true
    done

    # Fix cache permissions after sudo restores
    sudo chown -R "$USER:$USER" ~/.cache/restic
}

setup_uv() {
    curl --location --fail --retry 3 --retry-delay 2 --retry-all-errors \
        https://astral.sh/uv/install.sh | sh
    export PATH="$HOME/.local/bin:$PATH" # Add uv to PATH for script duration
}

setup_venvs() {
    mkdir "$HOME/venvs"

    local projects=(
        "alien_invasion" "data_visualization" "fish_tank" "infosec_forum"
        "ping" "port_scanner" "riven_sniper" "wfm"
    )

    # Loop over projects array, if directory exists on system, create virtual environment with corresponding requirements.txt file
    for project in "${projects[@]}"; do
        [[ -d "$HOME/python/projects/$project" ]] || continue
        uv venv "$HOME/venvs/$project" --python 3.13
        uv pip install --requirement "$HOME/python/projects/$project/requirements.txt" --python "$HOME/venvs/$project"
    done
}

setup_zsa_qmk_firmware() {
    git clone https://github.com/zsa/qmk_firmware.git "$HOME/zsa_qmk_firmware"
    # Pull in nested dependencies declared in .gitmodules
    (cd ~/zsa_qmk_firmware && git submodule update --init --recursive)
}

setup_jellyfin() {
    sudo mkdir --parents /srv/jellyfin/{movies,shows,educational}
    sudo mount --options remount,size=3G /tmp # Installer needs >= 2gb free space in /tmp
    curl --location --fail --retry 3 --retry-delay 2 --retry-all-errors \
        https://repo.jellyfin.org/install-debuntu.sh | sudo bash
}

setup_restic() {
    restic init --repo "$HOME/restic"
}

setup_services() {
    sudo systemctl enable --now nftables

    case "$MACHINE" in
        wsl)
            sudo systemctl enable --now sshd
            ;;
        pi)
            sudo systemctl enable --now ssh
            sudo systemctl enable --now riven-sniper
            curl --location --fail --retry 3 --retry-delay 2 --retry-all-errors \
                https://install.pi-hole.net | bash
            setup_jellyfin
            ;;
        kali)
            sudo systemctl enable --now ssh
            ;;
    esac
}

setup_wsl() {
    setup_locale
    update_system
    bootstrap_yay
    install_packages
    prompt_for_secrets
    restore_from_restic
    setup_venvs
    setup_zsa_qmk_firmware
    setup_services
}

setup_pi() {
    hush_login
    update_system
    install_packages
    install_optional_software
    prompt_for_secrets
    restore_from_restic
    setup_uv
    setup_venvs
    setup_restic
    setup_services
}

setup_kali() {
    hush_login
    update_system
    install_packages
    install_optional_software
    prompt_for_secrets
    restore_from_restic
    setup_services
}

main() {
    if ((UID == 0)); then
        echo "Do not run this script as root" >&2
        exit 1
    fi

    select_machine

    # Grant wheel group passwordless sudo
    sudo sed --in-place 's/# %wheel ALL=(ALL:ALL) ALL/%wheel ALL=(ALL:ALL) NOPASSWD: ALL/' "/etc/sudoers"

    case "$MACHINE" in
        wsl) setup_wsl ;;
        pi) setup_pi ;;
        kali) setup_kali ;;
    esac

    # Revoke wheel group passwordless sudo
    sudo sed --in-place 's/%wheel ALL=(ALL:ALL) NOPASSWD: ALL/%wheel ALL=(ALL:ALL) ALL/' "/etc/sudoers"

    # Set default shell to zsh
    chsh --shell "/usr/bin/zsh"

    exec zsh
}

main "$@"
