#!/usr/bin/env bash

# ================================================================================
# =                                    SETUP                                     =
# ================================================================================

set -euo pipefail

choose_machine() {
    while true; do
        read -r -p "Select machine [wsl/pi]: " MACHINE
        case "$MACHINE" in
            wsl | pi) break ;;
            *) echo "Invalid option" ;;
        esac
    done
}

bootstrap_secrets() {
    read -r -p "Enter Restic repository: " RESTIC_REPOSITORY
    read -r -p "Enter Restic password: " RESTIC_PASSWORD
    read -r -p "Enter B2 account ID: " B2_ACCOUNT_ID
    read -r -p "Enter B2 account key: " B2_ACCOUNT_KEY
}

bootstrap_yay() {
    sudo pacman -S --noconfirm git base-devel
    git clone https://aur.archlinux.org/yay.git
    (cd yay && makepkg --syncdeps --install --noconfirm)
    rm -rf yay
}

restore_from_restic() {
    :
}

setup_wsl() {
    sudo pacman -Syu --noconfirm
    bootstrap_yay
    yay -S --noconfirm - < <(curl --silent --show-error --location \
        https://raw.githubusercontent.com/jb49088/setup_script/master/packages/wsl/yay.txt)
    restore_from_restic
}

setup_pi() {
    echo "Hello from pi"
}

main() {
    # If piped to bash, re-execute as an interactive script to support read prompts
    if [[ "$0" == "bash" ]]; then
        exec bash <(curl --silent --show-error --location \
            https://raw.githubusercontent.com/jb49088/setup_script/master/setup)
    fi

    sudo -v
    choose_machine
    bootstrap_secrets

    case "$MACHINE" in
        wsl) setup_wsl ;;
        pi) setup_pi ;;
    esac
}

main
