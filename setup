#!/usr/bin/env bash

# ================================================================================
# =                                    SETUP                                     =
# ================================================================================

set -euo pipefail

select_machine() {
    while true; do
        read -r -p "Select machine [wsl/pi]: " MACHINE
        case "$MACHINE" in
            wsl | pi) break ;;
            *) echo "Invalid option" >&2 ;;
        esac
    done
}

prompt_for_secrets() {
    export RESTIC_REPOSITORY RESTIC_PASSWORD B2_ACCOUNT_ID B2_ACCOUNT_KEY

    while true; do
        read -r -p "Enter Restic repository: " RESTIC_REPOSITORY
        read -r -p "Enter Restic password: " RESTIC_PASSWORD
        read -r -p "Enter B2 account ID: " B2_ACCOUNT_ID
        read -r -p "Enter B2 account key: " B2_ACCOUNT_KEY

        restic snapshots &>/dev/null && return

        echo "Invalid credentials" >&2
    done
}

bootstrap_yay() {
    sudo pacman -S --noconfirm git base-devel
    git clone https://aur.archlinux.org/yay.git
    (cd yay && makepkg --syncdeps --install --noconfirm)
    rm -rf yay
}

install_packages() {
    case "$1" in
        wsl) curl --silent --show-error --location \
            https://raw.githubusercontent.com/jb49088/setup_script/master/packages/wsl/yay.txt \
            | xargs yay -S --noconfirm ;;

        pi) curl --silent --show-error --location \
            https://raw.githubusercontent.com/jb49088/setup_script/master/packages/pi/apt.txt \
            | xargs sudo apt install -yes ;;
    esac
}

update_system() {
    case "$1" in
        wsl) sudo pacman -Syu --noconfirm ;;
        pi) sudo apt update && sudo apt upgrade --yes ;;
    esac
}

restore_from_restic() {
    local tags=("bash" "databases" "direnv" "dotfiles" "helix" "history" "kakoune" "nftables" "nvim" "powershell" "python" "sql" "sqliterc" "ssh" "vault" "wsl" "wt" "zellij" "zsh")

    for tag in "${tags[@]}"; do
        restic restore latest --tag "$tag" --host "$1" --target / 2>/dev/null || true
    done
}

setup_venvs() {
    mkdir "$HOME/venvs"

    local projects=("alien_invasion" "data_visualization" "fish_tank" "infosec_forum" "ping" "port_scanner" "riven_sniper" "wfm")

    for project in "${projects[@]}"; do
        uv venv "$HOME/venvs/$project" --python 3.13 # Pin version for pre-built wheels
        uv pip install --requirement "$HOME/python/projects/$project/requirements.txt" --python "$HOME/venvs/$project"
    done
}

setup_wsl() {
    update_system "$MACHINE"
    bootstrap_yay
    install_packages "$MACHINE"
    prompt_for_secrets
    restore_from_restic "$MACHINE"
    setup_venvs
}

setup_pi() {
    update_system "$MACHINE"
    install_packages "$MACHINE"
    prompt_for_secrets
    restore_from_restic "$MACHINE"
}

main() {
    select_machine

    case "$MACHINE" in
        wsl) setup_wsl ;;
        pi) setup_pi ;;
    esac

    exec zsh
}

main
