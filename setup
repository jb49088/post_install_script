#!/usr/bin/env bash

# ================================================================================
# =                                    SETUP                                     =
# ================================================================================

set -euo pipefail

select_machine() {
    while true; do
        read -r -p "Select machine [wsl/pi]: " MACHINE
        case "$MACHINE" in
            wsl | pi) return ;;
            *) echo "Invalid option" >&2 ;;
        esac
    done
}

setup_user() {
    case "$1" in
        wsl) pacman -Sy --noconfirm sudo ;;
        pi) apt update && apt install --yes sudo ;;
    esac

    # Create user
    useradd --create-home --groups wheel master
    passwd master

    # Grant wheel group passwordless sudo
    sed --in-place 's/# %wheel ALL=(ALL:ALL) ALL/%wheel ALL=(ALL:ALL) NOPASSWD: ALL/' "/etc/sudoers"

    # Rerun setup as new user
    # script allows for interactive prompts to work under su --command
    # Pass in $1 so we dont get double promted for select_machine()
    su master --login --command 'script --quiet --command "bash <(curl --silent --show-error --location --fail \
        https://raw.githubusercontent.com/jb49088/setup_script/master/setup) '"$1"'" /dev/null'

    exit
}

setup_locale() {
    # Enable en_US.UTF-8 UTF-8
    sudo sed --in-place 's/# en_US.UTF-8 UTF-8/en_US.UTF-8 UTF-8/' /etc/locale.gen

    # Compile en_US.UTF-8 UTF-8
    sudo locale-gen

    # Set en_US.UTF-8 UTF-8 as default locale
    echo "LANG=en_US.UTF-8" | sudo tee /etc/locale.conf
}

update_system() {
    case "$1" in
        wsl) sudo pacman -Syu --noconfirm ;;
        pi) sudo apt update && sudo apt upgrade --yes ;;
    esac
}

bootstrap_yay() {
    sudo pacman -S --noconfirm git base-devel
    git clone https://aur.archlinux.org/yay.git "$HOME/yay"
    (cd "$HOME/yay" && makepkg --syncdeps --install --noconfirm) # Build arch package from source
    rm --recursive --force yay
}

install_packages() {
    case "$1" in
        # Get list of packages and pass it into corresponding package manager with xargs
        wsl) curl --silent --show-error --location --fail \
            https://raw.githubusercontent.com/jb49088/setup_script/master/packages/wsl/yay.txt \
            | xargs yay -S --noconfirm ;;

        pi) curl --silent --show-error --location --fail \
            https://raw.githubusercontent.com/jb49088/setup_script/master/packages/pi/apt.txt \
            | xargs sudo apt install --yes ;;
    esac
}

install_neovim() {
    # Get latest neovim release, decompress, and extract
    curl --silent --show-error --location --fail \
        https://github.com/neovim/neovim/releases/latest/download/nvim-linux-arm64.tar.gz \
        | gzip --decompress --stdout \
        | sudo tar --extract --file=- --directory=/opt

    # Link binary to /usr/local/bin/nvim for PATH access
    sudo ln --symbolic "/opt/nvim-linux-arm64/bin/nvim" "/usr/local/bin/nvim"
}

install_yazi() {
    local output="$HOME/yazi.deb"

    curl --silent --show-error --location --fail \
        https://github.com/sxyazi/yazi/releases/latest/download/yazi-aarch64-unknown-linux-gnu.deb \
        --output "$output"

    sudo apt install --yes "$output"

    rm "$output"
}

prompt_for_secrets() {
    export RESTIC_REPOSITORY RESTIC_PASSWORD B2_ACCOUNT_ID B2_ACCOUNT_KEY

    while true; do
        read -r -p "Enter Restic repository: " RESTIC_REPOSITORY
        read -r -s -p "Enter Restic password: " RESTIC_PASSWORD && echo
        read -r -p "Enter B2 account ID: " B2_ACCOUNT_ID
        read -r -s -p "Enter B2 account key: " B2_ACCOUNT_KEY && echo

        # Exit loop on valid credentials
        restic snapshots &>/dev/null && return

        echo "Invalid credentials" >&2
    done
}

restore_from_restic() {
    local tags=(
        "ssh" "wsl" "nftables" "services" "bash" "databases" "direnv" "dotfiles" "helix"
        "history" "kakoune" "nvim" "powershell" "python" "sql"
        "sqliterc" "vault" "wt" "zellij" "zsh"
    )

    # Loop over tags array and restore corresponding restic snapshots using sudo when necesary
    for tag in "${tags[@]}"; do
        local cmd="restic"
        [[ "$tag" == "wsl" || "$tag" == "nftables" || "$tag" == "services" ]] && cmd="sudo --preserve-env restic"
        $cmd restore latest --tag "$tag" --host "$1" --target / 2>/dev/null || true
    done

    # Fix cache permissions after sudo restores
    sudo chown -R master:master ~/.cache/restic
}

setup_uv() {
    curl --silent --show-error --location --fail https://astral.sh/uv/install.sh | sh
    export PATH="$HOME/.local/bin:$PATH" # Add uv to PATH for script duration
}

setup_venvs() {
    mkdir "$HOME/venvs"

    local projects=(
        "alien_invasion" "data_visualization" "fish_tank" "infosec_forum"
        "ping" "port_scanner" "riven_sniper" "wfm"
    )

    # Loop over projects array, if directory exists on system, create virtual environment with corresponding requirements.txt file
    for project in "${projects[@]}"; do
        [[ -d "$HOME/python/projects/$project" ]] || continue
        uv venv "$HOME/venvs/$project" --python 3.13
        uv pip install --requirement "$HOME/python/projects/$project/requirements.txt" --python "$HOME/venvs/$project"
    done
}

setup_zsa_qmk_firmware() {
    git clone https://github.com/zsa/qmk_firmware.git "$HOME/zsa_qmk_firmware"
    # Pull in nested dependencies declared in .gitmodules
    (cd ~/zsa_qmk_firmware && git submodule update --init --recursive)
}

setup_jellyfin() {
    sudo mkdir -p /srv/jellyfin/{movies,shows,educational}
    curl --silent --show-error --location --fail https://repo.jellyfin.org/install-debuntu.sh | sudo bash
}

setup_services() {
    sudo systemctl enable --now nftables

    case "$MACHINE" in
        wsl)
            sudo systemctl enable --now sshd
            ;;
        pi)
            sudo systemctl enable --now ssh
            sudo systemctl enable --now riven-sniper
            curl --silent --show-error --location --fail https://install.pi-hole.net | bash
            setup_jellyfin
            ;;
    esac
}

setup_wsl() {
    setup_locale
    update_system "$MACHINE"
    bootstrap_yay
    install_packages "$MACHINE"
    prompt_for_secrets
    restore_from_restic "$MACHINE"
    setup_venvs
    setup_zsa_qmk_firmware
    setup_services "$MACHINE"
}

setup_pi() {
    update_system "$MACHINE"
    install_packages "$MACHINE"
    install_neovim
    prompt_for_secrets
    restore_from_restic "$MACHINE"
    setup_uv
    setup_venvs
    setup_services "$MACHINE"
}

main() {
    if [[ -z "${1:-}" ]]; then
        select_machine
    else
        MACHINE="$1"
    fi

    # If current user is root, create user and rerun script
    ((UID == 0)) && setup_user "$MACHINE"

    # Grant wheel group passwordless sudo
    sudo sed --in-place 's/# %wheel ALL=(ALL:ALL) ALL/%wheel ALL=(ALL:ALL) NOPASSWD: ALL/' "/etc/sudoers"

    case "$MACHINE" in
        wsl) setup_wsl ;;
        pi) setup_pi ;;
    esac

    # Revoke wheel group passwordless sudo
    sudo sed --in-place 's/%wheel ALL=(ALL:ALL) NOPASSWD: ALL/%wheel ALL=(ALL:ALL) ALL/' "/etc/sudoers"

    # Set default shell to zsh
    chsh --shell "/usr/bin/zsh"

    exec zsh
}

main "$@"
